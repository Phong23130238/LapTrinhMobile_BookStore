<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/navy_dark"
            app:title="Quản trị viên"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xin chào, Admin!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/navy_dark"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <Button
            android:id="@+id/btnManageBooks"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="QUẢN LÝ KHO SÁCH"
            android:textSize="18sp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/navy_medium"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnManageOrders"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="QUẢN LÝ ĐƠN HÀNG"
            android:textSize="18sp"
            android:backgroundTint="@color/navy_medium"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnLogoutAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="60dp"
            android:text="Đăng xuất"
            android:textColor="@color/red_danger"
            style="@style/Widget.MaterialComponents.Button.TextButton" />
    </LinearLayout>
</LinearLayout>