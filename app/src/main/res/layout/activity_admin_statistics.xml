<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAdminStats"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        
        app:title="Thống Kê Kinh Doanh"
        
         />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Bộ lọc thời gian -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lọc theo thời gian"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/charcoal_dark"
                        android:layout_marginBottom="12dp"/>
                        
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFromDate"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Từ ngày"
                            android:textColor="@color/charcoal_dark"
                            app:strokeColor="@color/gray_border"/>
                            
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnToDate"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="12dp"
                            android:text="Đến ngày"
                            android:textColor="@color/charcoal_dark"
                            app:strokeColor="@color/gray_border"/>
                            
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterStats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xem"
                            app:cornerRadius="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tóm tắt số liệu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:baselineAligned="false">
                
                <!-- Tổng bán -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/violet_light"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đã bán (kỳ này)"
                            android:textColor="@color/white"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvTotalSoldQty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Tồn kho -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/navy_medium"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng tồn kho"
                            android:textColor="@color/white"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvTotalInventory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
            
            <!-- Tổng doanh thu -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng doanh thu trong khoảng thời gian"
                        android:textColor="@color/gray_text"
                        android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvTotalRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 đ"
                        android:textStyle="bold"
                        android:textColor="@color/green_success"
                        android:textSize="26sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_border"
                android:layout_marginVertical="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sách bán chạy nhất trong khoảng thời gian"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/charcoal_dark"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"/>
                
            <TextView
                android:id="@+id/tvEmptyTopBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa có dữ liệu bán hàng trong khoảng thời gian này."
                android:textAlignment="center"
                android:textColor="@color/gray_text"
                android:layout_margin="16dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTopBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_border"
                android:layout_marginVertical="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sách chưa phát sinh giao dịch trong khoảng thời gian"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/charcoal_dark"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"/>
                
            <TextView
                android:id="@+id/tvEmptyUnsoldBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tất cả sách đều đã được bán trong khoảng thời gian này!"
                android:textAlignment="center"
                android:textColor="@color/green_success"
                android:layout_margin="16dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvUnsoldBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>

