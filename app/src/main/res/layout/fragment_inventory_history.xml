<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:id="@+id/layoutHistoryFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#F8FAFC">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/svHistory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:queryHint="Tìm tên sách..."
            app:iconifiedByDefault="false"
            android:background="@drawable/bg_search_view" />

        <Spinner
            android:id="@+id/spinnerSortHistory"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/navy_dark" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvInventoryHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHistoryFilter"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/pbHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvHistoryEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Chưa có lịch sử xuất/nhập kho"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

</RelativeLayout>

