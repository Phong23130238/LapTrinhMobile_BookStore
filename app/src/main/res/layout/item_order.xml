<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#DH1001"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/navy_dark" />

            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="25/06/2026"
                android:textColor="#888888"
                android:textSize="14sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvCustomerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Khách hàng: Nguyễn Văn A"
            android:textColor="@color/navy_medium"
            android:textSize="15sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvTotalAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tổng tiền: 250,000 đ"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvPaymentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã TT (VNPay)"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="#4CAF50"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>

            <TextView
                android:id="@+id/tvShippingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="GHN: Đang giao"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="#FF9800"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>