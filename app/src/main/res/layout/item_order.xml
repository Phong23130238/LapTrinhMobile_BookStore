<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageView
            android:id="@+id/ivOrderIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_box"
            app:tint="@color/peach_accent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Thay đổi ID từ tvOrderId thành tvItemDisplayId -->
        <TextView
            android:id="@+id/tvItemDisplayId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:text="GHN123456789"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/ivOrderIcon"
            app:layout_constraintBottom_toBottomOf="@id/ivOrderIcon"
            app:layout_constraintStart_toEndOf="@id/ivOrderIcon"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:id="@+id/tvOrderDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25/06/2026 - 14:30"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintTop_toTopOf="@id/tvOrderId"
            app:layout_constraintBottom_toBottomOf="@id/tvOrderId"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/ivOrderIcon"/>

        <TextView
            android:id="@+id/tvTotalAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="250,000 đ"
            android:textColor="@color/violet_primary"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/badgesContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            app:layout_constraintTop_toTopOf="@id/tvTotalAmount"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPaymentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FEE2E2"
                android:layout_marginBottom="8dp">
                
                <TextView
                    android:id="@+id/tvPaymentStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa thanh toán"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#EF4444"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardShippingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FEF3C7">
                
                <TextView
                    android:id="@+id/tvShippingStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chờ xác nhận"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#D97706"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>